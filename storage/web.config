<?xml version="1.0" encoding="UTF-8"?>
<!--
  Pinoox storage — deny direct web access (IIS)
-->
<configuration>
  <system.webServer>
    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment="." />
        </hiddenSegments>
      </requestFiltering>
    </security>
    <authorization>
      <deny users="*" />
    </authorization>
    <handlers>
      <clear />
    </handlers>
    <staticContent>
      <clientCache cacheControlMode="DisableCache" />
    </staticContent>
  </system.webServer>
</configuration>
