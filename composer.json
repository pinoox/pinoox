{
  "name": "pinoox/pinoox",
  "description": "pinoox is a simple environment for web management and development. You can do whatever you want on the web and add your desire features to your website in a simple way",
  "keywords": [
    "PHP",
    "PHP Framework",
    "pinoox"
  ],
  "type": "project",
  "homepage": "http://www.pinoox.com/",
  "license": "MIT",
  "authors": [
    {
      "name": "Pinoox",
      "email": "dev@pinoox.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "pinoox/pincore": "^3.4"
  },
  "autoload": {
    "psr-4": {
      "App\\": "apps/"
    }
  },
  "bin": [
    "pinoox"
  ],
  "require-dev": {
    "nikic/php-parser": "^5.4",
    "nunomaduro/collision": "^8.5",
    "pestphp/pest": "^2.36",
    "pinoox/devdb": "^1.4",
    "pinoox/pinroll": "^1.0.5",
    "pinoox/pinx-inspector": "^1.3"
  },
  "scripts": {
    "check-platform": "@php platform/launcher/check.php",
    "dev": "@php pinoox dev",
    "test": "@php pinoox test platform",
    "test:core": "@php pinoox test platform",
    "test:apps": "@php pinoox test all"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "composer/package-versions-deprecated": true,
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
