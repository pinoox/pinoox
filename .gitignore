# =============================================================================
# Pinoox — runtime, secrets, generated artifacts
# =============================================================================

# Pincore (Core files for dev) (keep directory markers)
/pincore/
.pincore
# Baker cache & build output (~pinker)
/pinker/

# Writable storage (logs, cache, sessions, app files)
/storage/*
!/storage/.gitkeep
!/storage/.htaccess
!/storage/web.config
!/storage/nginx.conf
!/storage/Caddyfile
!/storage/**/.gitkeep

# User & package directories at project root
/uploads/
/downloads/

# Environment & local credentials
.env
.env.*
!.env.example

# Local dev sample packages (not for commit)
sample-dev-app.pinx

# Project pinx workspace (signing keys + export artifacts)
/pinx/
/pinx/keys/
/pinx/export/
/apps/*/pinx/
/apps/*/export/


# =============================================================================
# Project — PHP & Composer
# =============================================================================

/vendor/
/composer.lock
.phpunit.result.cache
.phpunit.cache
/auth.json
_ide_helper.php


# =============================================================================
# Project — Node.js & frontend tooling
# =============================================================================

node_modules/
package-lock.json


# =============================================================================
# Project — IDEs & editors
# =============================================================================

.idea/
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# Cursor (keep shared agent rules)
.cursor/*
.editorconfig
.zed/
.nova/
.phpactor.json
.codex/
Homestead.json
Homestead.yaml


# =============================================================================
# Project — OS & misc
# =============================================================================

**/.DS_Store
.DS_Store
Thumbs.db
*.log


# Generated test fixtures (keep directory markers)
tests/Fixtures/**/*
!tests/Fixtures/**/.gitkeep

# =============================================================================
# Apps — bundled system apps only (installer, manager, welcome)
# =============================================================================

/apps/*
!/apps/com_pinoox_installer/
!/apps/com_pinoox_installer/**
!/apps/com_pinoox_manager/
!/apps/com_pinoox_manager/**
!/apps/com_pinoox_welcome/
!/apps/com_pinoox_welcome/**

# macOS metadata inside whitelisted apps (must come after un-ignore rules)
**/.DS_Store
.DS_Store

# Local platform overrides (never pushed)
/platform/*.local.php
/platform/**/*.local.php

# Themes
/themes/*/.pinoox/