# =============================================================================
# Pinoox — runtime, secrets, generated artifacts
# =============================================================================

# Pincore (Core files for dev) (keep directory markers)
/pincore/
.pincore
# Baker cache & build output (~pinker)
/pinker/

# Writable storage (logs, cache, sessions, app files)
/storage/*
!/storage/.gitkeep
!/storage/.htaccess
!/storage/web.config
!/storage/nginx.conf
!/storage/Caddyfile
!/storage/**/.gitkeep

# User & package directories at project root
/uploads/
/downloads/

# Environment & local credentials
.env
.env.*
!.env.example

# Local MAMP / PHP error dumps inside apps
**/MAMP_php_error_log*

# Cursor editor (local rules; see global gitignore)
.cursor/

# Node Js
node_modules
package-lock.json
