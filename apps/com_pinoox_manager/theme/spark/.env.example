# PHP backend origin — used first to build __PINOOX__.url (APP, API, SITE, …)
VITE_SERVER_URL=http://127.0.0.1:8000

# App public path (match url().appPath() without project prefix)
VITE_APP_PATH=/manager

# Optional when Pinoox runs in a subfolder (e.g. /pinoox/manager)
# VITE_PROJECT_PATH=/pinoox

# Optional overrides (usually auto-derived from VITE_SERVER_URL + VITE_APP_PATH)
# VITE_API_PATH=/manager/api/v1/
# VITE_LOCALE=fa
