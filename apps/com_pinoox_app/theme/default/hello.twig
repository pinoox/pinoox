<!DOCTYPE html>
<html lang="{{ currentLang|default('en') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title|default('App') }}</title>
    <style>
        body { font-family: system-ui, sans-serif; background: #f4f6f8; margin: 0; min-height: 100vh; display: grid; place-items: center; }
        .card { background: #fff; padding: 2rem 2.5rem; border-radius: 12px; box-shadow: 0 8px 24px rgba(0,0,0,.08); max-width: 520px; text-align: center; }
        h1 { margin: 0 0 .75rem; font-size: 1.5rem; }
        p { margin: 0; color: #555; line-height: 1.6; }
    </style>
</head>
<body>
    <div class="card">
        <h1>{{ title }}</h1>
        <p>{{ message }}</p>
    </div>
</body>
</html>
