<?php

/**
 * App test bootstrap — loads platform tests and reads package from app.php.
 *
 * Loaded automatically by: php pinoox test {{package}}
 * Manual run: php vendor/bin/pest apps/{{package}}/tests --bootstrap=apps/{{package}}/tests/bootstrap.php --configuration=phpunit.xml
 */
require dirname(__DIR__, 3) . '/tests/bootstrap.php';

\Pinoox\Component\Test\AppTestKit::setPackage(
    \Pinoox\Component\Test\AppTestKit::packageFromAppDir(dirname(__DIR__)),
);
