# Pinoox runtime
APP_NAME=Pinoox
APP_ENV=development
APP_DEBUG=true
APP_KEY=
APP_URL=http://localhost
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
PINOOX_VERSION_CODE=20
PINOOX_VERSION_NAME=2.2.0
PINOOX_MODE=development
PINOOX_LANG=en
PINOOX_LANG_FALLBACK=en
PINOOX_TIMEZONE=UTC
BCRYPT_ROUNDS=12

# Core locations
PINOOX_CORE_PATH=pincore
PINOOX_SYSTEM_PATH=system
PINOOX_APPS_PATH=apps
PINOOX_PINKER_PATH=pinker
PINOOX_STORAGE_PATH=storage
PINOOX_RESOURCES_PATH=resources

# System resources
PINOOX_SYSTEM_CONFIG_PATH=~system/config
PINOOX_SYSTEM_LANG_PATH=~system/lang
PINOOX_SYSTEM_MIGRATIONS_PATH=~system/database/migrations
PINOOX_SYSTEM_MODELS_PATH=~system/Model
PINOOX_SYSTEM_REGISTRY_PATH=~system/config/apps.config.php
PINOOX_SYSTEM_ROUTER_PATH=~system/config/app/router.config.php
PINOOX_SYSTEM_RESOURCE_PATH=~system/resource
PINOOX_SYSTEM_RESOURCE_VIEWS_PATH=~system/resource/views

# App resources
PINOOX_APP_FILE=app.php
PINOOX_APP_CONFIG_PATH=config
PINOOX_APP_LANG_PATH=lang
PINOOX_APP_MIGRATIONS_PATH=migrations

# Generated/cache paths
PINOOX_STUBS_PATH=~pincore/stubs
PINOOX_WIZARD_TMP_PATH=~pinker/wizard_tmp

# Logs
PINOOX_LOG_PATH=~storage/logs/pinoox.log
LOG_CHANNEL=app
LOG_LEVEL=debug
PINOOX_LOG_CHANNEL=app
PINOOX_LOG_LEVEL=debug

# Cache
CACHE_STORE=file
CACHE_PREFIX=pinoox
CACHE_PATH=~storage/cache
CACHE_TTL=0

# Redis
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PREFIX=pinoox:
REDIS_CONNECTION=default
REDIS_TIMEOUT=1.0
REDIS_READ_TIMEOUT=1.0
REDIS_PERSISTENT=false
REDIS_CACHE_CONNECTION=cache
REDIS_CACHE_DB=1
REDIS_CACHE_PREFIX=pinoox:cache:
# CACHE_STORE=redis

# Session
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SAVE_PATH=~storage/sessions
SESSION_COOKIE=pinoox_session
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# Database
DB_CONNECTION=test
DB_TEST_DRIVER=sqlite
DB_TEST_DATABASE=:memory:
DB_TEST_PREFIX=
DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pinoox
DB_USERNAME=root
DB_PASSWORD=root
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_bin
DB_PREFIX=pinx_
DB_STRICT=true
DB_ENGINE=
DB_TIMEZONE=+03:30

# Filesystems
FILESYSTEM_DISK=local
FILESYSTEM_CLOUD=s3
FILESYSTEM_APP_DISK=local
FILESYSTEM_LOCAL_ROOT=~storage/app
FILESYSTEM_PUBLIC_ROOT=~storage/app/public
FILESYSTEM_APPS_ROOT=~storage/apps
FILESYSTEM_APPS_PREFIX=apps
FILESYSTEM_TEMP_ROOT=~storage/tmp
FILESYSTEM_PUBLIC_LINK=storage
FILESYSTEM_PUBLIC_URL=
FILESYSTEM_THROW=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Services
PINOOX_SERVICE_DEBUGGER=~debugger
PINOOX_SERVICE_CONSOLE=~console
PINOOX_SERVICE_DATABASE=~database
PINOOX_SERVICE_BOOT=~boot
PINOOX_SERVICE_CACHE=~cache
PINOOX_SERVICE_REDIS=~redis
PINOOX_SERVICE_LOGGER=~logger
