# Copy to .env: cp .env.example .env
#
# Docker: runtime image = framework infrastructure only (see docker/README.md).
# Compose project name: pinoox (docker-compose.yml)

APP_PORT=8080

MYSQL_PORT=3307
MYSQL_DATABASE=pinoox
MYSQL_USER=pinoox
MYSQL_PASSWORD=pinoox
MYSQL_ROOT_PASSWORD=root

# Node.js version for docker/pinoox/Dockerfile (build arg)
NODE_VERSION=22.12.0

# Pinoox runtime — production is secure-by-default; cloned repos use development below.
# Production deploy: APP_ENV=production and DB_CONNECTION=mysql
APP_NAME=Pinoox
APP_ENV=development
# MODE=production
# APP_DEBUG defaults: production=false, other modes=true — set explicitly to override
# APP_DEBUG=false
# Pinoox Exception page (independent of APP_DEBUG) — defaults to true in all modes
# PINOOX_EXCEPTION=true
APP_KEY=
APP_URL=http://localhost
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Optional — override core path (auto-detects ./pincore when cloned for local dev)
# PINOOX_CORE_PATH=vendor/pinoox/pincore
# PINOOX_CONFIG_PATH=vendor/pinoox/pincore/config
# PINOOX_APPS_PATH=apps
# PINOOX_PINKER_PATH=pinker
# PINOOX_STORAGE_PATH=storage
# Local dev registry: copy platform/apps.config.php → apps.config.local.php, then customize packages
# PINOOX_PROJECT_REGISTRY_PATH=~/platform/apps.config.local.php

# Logs
LOG_PATH=~storage/logs/pinoox.log
LOG_CHANNEL=pinoox
LOG_LEVEL=debug

# Cache
CACHE_STORE=file
CACHE_PREFIX=pinoox
CACHE_PATH=~storage/cache
CACHE_TTL=0

# Redis
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PREFIX=pinoox:
REDIS_CONNECTION=default
REDIS_TIMEOUT=1.0
REDIS_READ_TIMEOUT=1.0
REDIS_PERSISTENT=false
REDIS_CACHE_CONNECTION=cache
REDIS_CACHE_DB=1
REDIS_CACHE_PREFIX=pinoox:cache:
# CACHE_STORE=redis

# Session
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SAVE_PATH=~storage/sessions
SESSION_COOKIE=pinoox_session
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# Database — DB_CONNECTION: auto|devdb|mysql|mariadb|pgsql|sqlsrv|sqlite
# Development defaults to devdb when DB_CONNECTION is unset (zero-setup local DB).
DB_CONNECTION=devdb
# DB_URL=
DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pinoox
DB_USERNAME=root
DB_PASSWORD=root
# DB_SOCKET=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_bin
DB_PREFIX=pinx_
DB_PREFIX_INDEXES=true
DB_STRICT=true
DB_ENGINE=
DB_TIMEZONE=+03:30
# DB_FOREIGN_KEYS=true
# DB_SSLMODE=prefer
# DB_SCHEMA=public
# MYSQL_ATTR_SSL_CA=
# DB_MIGRATIONS_TABLE=history

# PostgreSQL example: DB_CONNECTION=pgsql  DB_PORT=5432
# SQL Server example: DB_CONNECTION=sqlsrv  DB_PORT=1433  DB_HOST=localhost
# MariaDB example:   DB_CONNECTION=mariadb
# Production example: APP_ENV=production  DB_CONNECTION=mysql
# MySQL in development: DB_CONNECTION=mysql  (or auto to probe mysql first)
# Testing (.env.test): APP_ENV=test — defaults to devdb; override with DB_CONNECTION=sqlite for :memory:

# Date (platform defaults — international)
DATE_TIMEZONE=UTC
DATE_CALENDAR=gregorian

# Filesystems
FILESYSTEM_DISK=local
FILESYSTEM_CLOUD=s3
FILESYSTEM_APP_DISK=local
FILESYSTEM_LOCAL_ROOT=~storage/app
FILESYSTEM_PUBLIC_ROOT=~storage/app/public
FILESYSTEM_APPS_ROOT=~storage/apps
FILESYSTEM_APPS_PREFIX=apps
FILESYSTEM_TEMP_ROOT=~storage/tmp
FILESYSTEM_PUBLIC_LINK=storage
FILESYSTEM_PUBLIC_URL=
FILESYSTEM_THROW=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Security
BCRYPT_ROUNDS=12

# Optional server auto-login for local/dev only (manual). CLI does not set this.
# Multiple lines OK — each request uses the line matching the active app package.
# PINOOX_LOGIN=com_pinoox_manager:id:1
# PINOOX_LOGIN=com_pinoox_manager:user_id:1
# PINOOX_LOGIN=com_pinoox_manager:personal_id:1
# PINOOX_LOGIN=com_pinoox_account:username:yoosef
# PINOOX_LOGIN=com_pinoox_app:email:info@pinoox.com
# PINOOX_LOGIN=com_pinoox_shop:mobile:09122220000

# CLI token auto-login (written by: user:login --force, cleared by: user:logout --force)
# PINOOX_LOGIN_TOKEN=

# Domain routing (optional)
# PINOOX_DOMAIN=https://example.com
